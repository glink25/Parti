{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] },
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "types": ["vite/client"],
    "noEmit": false
  },
  "include": ["src/**/*", "src/i18n/messages/*.json"],
  "references": [
    { "path": "../../packages/core" },
    { "path": "../../packages/worker-sdk" },
    { "path": "../../packages/client-sdk" },
    { "path": "../../packages/transport-local" },
    { "path": "../../packages/transport-peerjs" },
    { "path": "../../packages/transport-common" },
    { "path": "../../packages/room-packager" }
  ]
}
