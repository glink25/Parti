{
  "partiVersion": "0.1.0",
  "protocolVersion": 1,
  "id": "room-magicka",
  "name": "元素训练场",
  "version": "0.1.0",
  "packageMode": "filesystem",
  "description": "组合七种元素，在无尽训练场中测试法术反应",
  "_template_order": 102,
  "author": { "name": "Parti" },
  "entry": { "ui": "index.html", "worker": "worker.js" },
  "room": { "minPlayers": 1, "maxPlayers": 4 },
  "sync": { "mode": "snapshot" },
  "permissions": { "network": false, "storage": "session", "camera": false, "microphone": false, "clipboard": false, "sensors": [] },
  "actions": {
    "setReady": { "payload": "{ ready: boolean }" },
    "restart": {},
    "advanceStage": {},
    "equipItem": { "payload": "{ itemId: string }" },
    "dropItem": { "payload": "{ itemId: string }" },
    "pickupLoot": { "payload": "{ lootId: string }" },
    "toggleLootWant": { "payload": "{ lootId: string }" },
    "buyItem": { "payload": "{ merchantId: string, itemId: string }" },
    "awardGold": { "payload": "{ eventId: string, playerIds: string[], amount: number }" },
    "exploreRoom": { "payload": "{ roomId: string }" },
    "publishPlayer": { "payload": "PlayerReport" },
    "syncWorld": { "payload": "HostWorldReport" },
    "reportEnemyDamage": { "payload": "EnemyDamageReport" },
    "reportPlayerEffect": { "payload": "PlayerEffectReport" },
    "reportEnvironment": { "payload": "EnvironmentState" },
    "reportProjectileHit": { "payload": "{ projectileId: string }" }
  }
}
