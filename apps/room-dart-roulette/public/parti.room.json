{
  "partiVersion": "0.1.0",
  "protocolVersion": 1,
  "id": "dart-roulette",
  "name": "飞镖轮盘",
  "version": "0.2.0",
  "packageMode": "filesystem",
  "cover": "cover.jpg",
  "description": "围绕不停旋转的木质标靶轮流发射飞镖，贴近对手得分，碰镖扣血，并应对不断变化的轮盘事件。",
  "tags": ["party", "action", "multiplayer"],
  "author": { "name": "Parti" },
  "entry": {
    "ui": "index.html",
    "worker": "worker.js"
  },
  "room": {
    "minPlayers": 2,
    "maxPlayers": 8,
    "allowSpectators": false
  },
  "sync": { "mode": "snapshot" },
  "permissions": {
    "network": false,
    "storage": "session",
    "camera": false,
    "microphone": false,
    "clipboard": false,
    "sensors": []
  },
  "actions": {
    "start_game": {},
    "accept_turn": { "payload": "{ turnId, revision }" },
    "commit_shot": { "payload": "ShotCommit" },
    "commit_timeout": { "payload": "TimeoutCommit" },
    "return_to_lobby": {}
  }
}
