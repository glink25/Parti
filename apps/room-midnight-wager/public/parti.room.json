{
  "partiVersion": "0.1.0",
  "protocolVersion": 1,
  "id": "room-midnight-wager",
  "name": "午夜赌局",
  "version": "0.1.0",
  "packageMode": "filesystem",
  "description": "2–4 人原创惊悚诈唬牌局：经典、恶魔与混沌三种规则，谎言败露后亲手扣动扳机。",
  "cover": "cover.jpg",
  "author": { "name": "Parti" },
  "_template_order": 95,
  "entry": {
    "ui": "index.html",
    "worker": "worker.js"
  },
  "room": {
    "minPlayers": 2,
    "maxPlayers": 4,
    "allowSpectators": false
  },
  "sync": { "mode": "snapshot" },
  "permissions": {
    "network": false,
    "storage": "session",
    "camera": false,
    "microphone": false,
    "clipboard": false,
    "sensors": []
  },
  "actions": {
    "setReady": { "payload": "{ ready: boolean }" },
    "setRuleset": { "payload": "{ ruleset: 'classic' | 'devil' | 'chaos' }" },
    "playCards": { "payload": "{ cardIds: string[] }" },
    "callLiar": {},
    "callDevilsDeal": {},
    "pullTrigger": { "payload": "{ targetId?: string }" },
    "syncPrivate": {},
    "abortMatch": {}
  }
}
