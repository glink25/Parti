{
  "partiVersion": "0.1.0",
  "protocolVersion": 1,
  "id": "room-doudizhu",
  "name": "斗地主",
  "version": "0.1.0",
  "packageMode": "filesystem",
  "description": "三人联机斗地主：准备、叫地主、完整出牌校验和实时累计计分。",
  "tags": ["tabletop", "turn-based"],
  "cover": "cover.png",
  "author": { "name": "Parti" },
  "_template_order": 90,
  "entry": {
    "ui": "index.html",
    "worker": "worker.js"
  },
  "room": {
    "minPlayers": 3,
    "maxPlayers": 3
  },
  "sync": { "mode": "snapshot" },
  "permissions": {
    "network": false,
    "storage": "session",
    "camera": false,
    "microphone": false,
    "clipboard": false
  },
  "actions": {
    "setReady": { "payload": "{ ready: boolean }" },
    "bid": { "payload": "{ score: 0 | 1 | 2 | 3 }" },
    "playCards": { "payload": "{ cardIds: string[] }" },
    "pass": {},
    "syncHand": {}
  }
}
