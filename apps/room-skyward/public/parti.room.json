{
  "partiVersion": "0.1.0",
  "protocolVersion": 1,
  "id": "room-skyward",
  "name": "云端远征",
  "version": "0.1.0",
  "packageMode": "filesystem",
  "description": "跳跃，合作，疯狂！",
  "author": { "name": "Parti" },
  "entry": { "ui": "index.html", "worker": "worker.js" },
  "room": { "minPlayers": 1, "maxPlayers": 4 },
  "sync": { "mode": "snapshot" },
  "permissions": {
    "network": false,
    "storage": "session",
    "camera": false,
    "microphone": false,
    "clipboard": false
  },
  "actions": {
    "setReady": { "payload": "{ ready: boolean }" },
    "restart": {},
    "move": { "payload": "{ direction: -1 | 0 | 1 }" },
    "telemetry": { "payload": "{ x: number, y: number, vy: number, cameraBottom: number }" },
    "shoot": { "payload": "{ shotId: string, x: number, y: number }" },
    "resolveHit": { "payload": "{ shotId: string, projectileIndex: number, targetId: string }" },
    "stomp": { "payload": "{ enemyId: string }" },
    "claimPickup": { "payload": "{ pickupId: string }" },
    "activateRelay": { "payload": "{ chunkIndex: number }" },
    "reportDeath": { "payload": "{ reason: 'void' | 'enemy' }" },
    "enableTilt": { "payload": "{ enabled: boolean }" }
  }
}
