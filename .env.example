# 部署 Supabase 大厅后，在 Parti Web 环境设置（见 services/lobby-supabase/README.md）
VITE_LOBBY_SERVICE_URL=https://<project-ref>.supabase.co/functions/v1/parti-lobby
# GA4 gtag 完整 HTML 片段（单行），留空则不注入；仅构建时使用，不暴露到客户端 JS
GA_MEASUREMENT_SNIPPET=<script async src="https://www.googletagmanager.com/gtag/js?id=G-MSL4LSH1RT"></script><script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-MSL4LSH1RT');</script>
