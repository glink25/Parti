# 部署 Supabase 大厅后，在 Parti Web 环境设置（见 services/lobby-supabase/README.md）
VITE_LOBBY_SERVICE_URL=https://<project-ref>.supabase.co/functions/v1/parti-lobby
# Common 适配器的 Supabase Realtime 实现（仅使用浏览器可公开的 publishable/anon key）
VITE_COMMON_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_COMMON_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<key>
# 房间市场的 GitHub issue 注册表（默认 glink25/Parti），自建市场时覆盖
VITE_MARKET_REGISTRY=<owner>/<repo>
# GA4 gtag 完整 HTML 片段（单行），留空则不注入；仅构建时使用，不暴露到客户端 JS
GA_MEASUREMENT_SNIPPET=